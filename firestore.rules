rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tenantMatch(tenantId) {
      return signedIn() && request.auth.token.tenant_id == tenantId;
    }

    function isPlatformAdmin() {
      return signedIn() && request.auth.token.platform_admin == true;
    }

    match /platform/plans/{planId} {
      allow read: if signedIn();
      allow write: if isPlatformAdmin();
    }

    match /platform/tenants/{tenantId} {
      allow read: if tenantMatch(tenantId) || isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    match /tenants/{tenantId}/{document=**} {
      allow read, write: if tenantMatch(tenantId) || isPlatformAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
